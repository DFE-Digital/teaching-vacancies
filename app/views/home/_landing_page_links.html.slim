.landing-page-links
  = govuk_accordion do |accordion|
    - accordion.with_section(heading_text: t(".jobs_by_school_type_and_role")) do
      = render "jobs_by_type_section",
          counts: school_counts,
          teaching_roles_list: landing_page_teaching_roles_list,
          support_roles_list: landing_page_support_roles_list,
          phases_heading: t(".education_phases"),
          phases_list: landing_page_phases_list,
          working_patterns_list: landing_page_working_patterns_list,
          subjects_columns: landing_page_subjects_columns,
          tallied_subjects: landing_page_tallier(school_counts.subjects_counts)
    - accordion.with_section(heading_text: t(".jobs_by_fe_type_and_role")) do
      = render "jobs_by_type_section",
          counts: fe_counts,
          teaching_roles_list: landing_page_fe_teaching_roles_list,
          support_roles_list: landing_page_fe_support_roles_list,
          phases_heading: t(".fe_phases"),
          phases_list: [],
          working_patterns_list: landing_page_fe_working_patterns_list,
          subjects_columns: landing_page_fe_subjects_columns,
          tallied_subjects: landing_page_fe_tallier(fe_counts.subjects_counts)
    - accordion.with_section(heading_text: t(".jobs_by_location")) do
      = render "regional_counts_section"

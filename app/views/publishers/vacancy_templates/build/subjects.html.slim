= form_for @form, url: wizard_path, method: :patch do |f|
  = f.govuk_error_summary

  div class="govuk-!-margin-bottom-6"
    = searchable_collection(collection: f.govuk_collection_check_boxes(:subjects,
      SUBJECT_OPTIONS,
      :first,
      :first,
      :last,
      legend: nil,
      hint: nil,
      classes: "checkbox-label__bold"),
      collection_count: SUBJECT_OPTIONS.count,
      options: { border: true },
      text: { aria_label: "search subjects" })

  .govuk-button-group
    = f.govuk_submit t("buttons.save_and_continue")
    = f.govuk_submit t("buttons.save_and_finish_later"), name: "save_and_finish_later", value: "true", secondary: true

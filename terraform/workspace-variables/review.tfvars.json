{
  "app_environment": "review",
  "channel_list": {},
  "aks_web_app_start_command": [
    "/bin/sh",
    "-c",
    "bundle exec rails db:prepare:ignore_concurrent_migration_exceptions db:async_seed && rails s"
  ],
  "parameter_store_environment": "dev",
  "region": "eu-west-2",
  "cluster": "test",
  "namespace": "tv-development",
  "azure_enable_backup_storage": false,
  "deploy_azure_backing_services": false,
  "enable_monitoring": false,
  "enable_postgres_ssl": false,
  "add_database_name_suffix": false,
  "route53_zones": [],
  "enable_logit": true,
  "enable_dfe_analytics_federated_auth": true,
  "dataset_name": "staging_dataset",
  "azure_storage_blob_delete_retention_days": null,
  "azure_storage_blob_versioning_enabled": false,
  "azure_storage_blob_delete_after_days": 7,
  "azure_storage_cors_allowed_origins": ["https://*.test.teacherservices.cloud"]
}
